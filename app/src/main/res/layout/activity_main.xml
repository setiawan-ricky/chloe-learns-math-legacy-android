<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- Title row with heart + text + unicorn -->
    <LinearLayout
        android:id="@+id/titleRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/imgHeart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/txtChloe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="chloe "
            android:textSize="38sp"
            android:textColor="#F48FB1" />

        <TextView
            android:id="@+id/txtLearnsMath"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="learns math"
            android:textSize="38sp"
            android:textColor="#B39DDB" />

        <ImageView
            android:id="@+id/imgBlackboard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="fitCenter"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- Language flag selector -->
    <LinearLayout
        android:id="@+id/flagRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/imgFlagUs"
            android:layout_width="48dp"
            android:layout_height="32dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <ImageView
            android:id="@+id/imgFlagCn"
            android:layout_width="48dp"
            android:layout_height="32dp"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Bounce zone: fills all available space between title and buttons -->
    <FrameLayout
        android:id="@+id/bounceZone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="true">

        <ImageView
            android:id="@+id/imgBounce"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/imgBounce2"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/imgBounce3"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="fitCenter" />

    </FrameLayout>

    <!-- Two-column game buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <!-- Addition column -->
        <LinearLayout
            android:id="@+id/colAddition"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/txtAddition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="addition"
                android:textSize="30sp"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.10"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true" />

            <FrameLayout
                android:id="@+id/btnAdditionEasy"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnAdditionEasy" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="easy"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnAdditionEasy" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnAdditionHard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnAdditionHard" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="hard"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnAdditionHard" />
            </FrameLayout>

        </LinearLayout>

        <!-- Spelling column (English mode) -->
        <LinearLayout
            android:id="@+id/colSpelling"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingEnd="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtSpelling"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="spelling"
                android:textSize="30sp"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.10"
                android:layout_marginBottom="10dp" />

            <FrameLayout
                android:id="@+id/btnSpellingEasy"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnSpellingEasy" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="easy"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnSpellingEasy" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnSpellingHard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnSpellingHard" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="hard"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnSpellingHard" />
            </FrameLayout>

        </LinearLayout>

        <!-- Games played today counter -->
        <LinearLayout
            android:id="@+id/todayCounter"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/txtTodayCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="48sp"
                android:textColor="#3F51B5" />

            <TextView
                android:id="@+id/txtTodayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="times played today"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:gravity="center" />

        </LinearLayout>

        <!-- LSCWC column (English mode, between today counter and minus) -->
        <LinearLayout
            android:id="@+id/colLscwc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtLscwc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="look say"
                android:textSize="30sp"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.10"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <FrameLayout
                android:id="@+id/btnLscwcStart"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnLscwcStart" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="start"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnLscwcStart" />
            </FrameLayout>

        </LinearLayout>

        <!-- Minus column -->
        <LinearLayout
            android:id="@+id/colMinus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/txtMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="minus"
                android:textSize="30sp"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.10"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true" />

            <FrameLayout
                android:id="@+id/btnMinusEasy"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnMinusEasy" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="easy"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnMinusEasy" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnMinusHard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnMinusHard" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="hard"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnMinusHard" />
            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom row: history + stats -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <FrameLayout
            android:id="@+id/btnHistory"
            android:layout_width="160dp"
            android:layout_height="80dp"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:id="@+id/imgBtnHistory" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="history"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:shadowColor="#4D000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:id="@+id/txtBtnHistory" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnModeToggle"
            android:layout_width="160dp"
            android:layout_height="80dp"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:id="@+id/imgBtnModeToggle" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="chloe learns english"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:shadowColor="#4D000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:id="@+id/txtBtnModeToggle" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnStats"
            android:layout_width="160dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:id="@+id/imgBtnStats" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="stats"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:shadowColor="#4D000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:id="@+id/txtBtnStats" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
