<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- Title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chloe Learns Math"
        android:textSize="38sp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:clickable="true"
        android:focusable="true" />

    <!-- Bounce zone: fills all available space between title and buttons -->
    <FrameLayout
        android:id="@+id/bounceZone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="true">

        <ImageView
            android:id="@+id/imgBounce"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/imgBounce2"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="fitCenter" />

    </FrameLayout>

    <!-- Two-column game buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <!-- Addition column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/txtAddition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADDITION"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.10"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true" />

            <Button
                android:id="@+id/btnAdditionEasy"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Easy"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_easy"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAdditionHard"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Hard"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_hard" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E0E0E0" />

        <!-- Minus column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/txtMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MINUS"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.10"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true" />

            <Button
                android:id="@+id/btnMinusEasy"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Easy"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_easy"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnMinusHard"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Hard"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_hard" />

        </LinearLayout>
    </LinearLayout>

    <!-- History button -->
    <Button
        android:id="@+id/btnHistory"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:layout_gravity="center_horizontal"
        android:text="History"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_game_card"
        android:layout_marginBottom="20dp" />

</LinearLayout>
