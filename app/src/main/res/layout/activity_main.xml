<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- Title row with heart + text + unicorn -->
    <LinearLayout
        android:id="@+id/titleRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/imgHeart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/txtChloe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="chloe "
            android:textSize="38sp"
            android:textColor="#F48FB1" />

        <TextView
            android:id="@+id/txtLearnsMath"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="learns math"
            android:textSize="38sp"
            android:textColor="#B39DDB" />

        <ImageView
            android:id="@+id/imgUnicorn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="fitCenter"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- Bounce zone: fills all available space between title and buttons -->
    <FrameLayout
        android:id="@+id/bounceZone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="true">

        <ImageView
            android:id="@+id/imgBounce"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/imgBounce2"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="fitCenter" />

    </FrameLayout>

    <!-- Two-column game buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <!-- Addition column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/txtAddition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="addition"
                android:textSize="30sp"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.10"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true" />

            <FrameLayout
                android:id="@+id/btnAdditionEasy"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnAdditionEasy" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="easy"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnAdditionEasy" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnAdditionHard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@color/transparent"
                    android:id="@+id/imgBtnAdditionHard" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="hard"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnAdditionHard" />
            </FrameLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E0E0E0" />

        <!-- Minus column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/txtMinus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="minus"
                android:textSize="30sp"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.10"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true" />

            <FrameLayout
                android:id="@+id/btnMinusEasy"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnMinusEasy" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="easy"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnMinusEasy" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnMinusHard"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:id="@+id/imgBtnMinusHard" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="hard"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#4D000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="3"
                    android:id="@+id/txtBtnMinusHard" />
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Bottom row: history + stats -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <FrameLayout
            android:id="@+id/btnHistory"
            android:layout_width="160dp"
            android:layout_height="80dp"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:id="@+id/imgBtnHistory" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="history"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:shadowColor="#4D000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:id="@+id/txtBtnHistory" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnStats"
            android:layout_width="160dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:id="@+id/imgBtnStats" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="stats"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:shadowColor="#4D000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:id="@+id/txtBtnStats" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
